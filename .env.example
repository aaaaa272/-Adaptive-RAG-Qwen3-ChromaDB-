# 阿里云百炼 API 配置（兼容 OpenAI 接口）
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型配置
QWEN_CHAT_MODEL=qwen3-8b
QWEN_EMBEDDING_MODEL=text-embedding-v3

# Cohere 重排序（可选，留空则用本地重排序）
COHERE_API_KEY=

# LangSmith 追踪（可选）
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=kaoyan-rag

# ChromaDB 路径
CHROMA_DB_PATH=./data/chroma_db
CHROMA_COLLECTION_NAME=kaoyan_knowledge

# RAG 参数
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_VECTOR=10
TOP_K_BM25=10
TOP_K_FINAL=5
